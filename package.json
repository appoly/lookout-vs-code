{
  "name": "lookout",
  "displayName": "Lookout",
  "description": "Run, monitor, and review Codex, Claude Code, and custom terminal agents in parallel without leaving VS Code.",
  "version": "0.1.0",
  "publisher": "adamh",
  "license": "MIT",
  "preview": true,
  "pricing": "Free",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#101827",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamhulme/lookout-vs-code.git"
  },
  "homepage": "https://github.com/adamhulme/lookout-vs-code#readme",
  "bugs": {
    "url": "https://github.com/adamhulme/lookout-vs-code/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "multi-agent",
    "terminal",
    "agents",
    "codex",
    "codex cli",
    "claude",
    "claude code",
    "worktree",
    "code review",
    "usage limits",
    "orchestration",
    "multiplexer"
  ],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Review and usage views remain available; launching configured terminal commands requires a trusted workspace.",
      "restrictedConfigurations": [
        "lookout.codex.command",
        "lookout.claude.command",
        "lookout.usage.codex.executable"
      ]
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Lookout requires native terminals, local or remote filesystem paths, and Git processes."
    }
  },
  "files": [
    "out/src/**",
    "resources/**",
    "README.md",
    "CHANGELOG.md",
    "PRIVACY.md",
    "SECURITY.md",
    "SUPPORT.md",
    "LICENSE"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run clean && npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "lint": "eslint src test",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "test:integration": "npm run compile && vscode-test --label integration --fail-zero --forbid-only",
    "verify:vsix": "npm run vsix && node scripts/verify-vsix.mjs",
    "check": "npm run lint && npm test",
    "check:all": "npm run check && npm run test:integration",
    "audit:runtime": "npm audit --omit=dev",
    "check:release": "npm run check:all && npm run audit:runtime && npm run verify:vsix",
    "vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.13",
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "lookout.launchAgent",
        "title": "New Agent…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.launchCodex",
        "title": "Launch Codex Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.launchClaude",
        "title": "Launch Claude Code Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.launchCustom",
        "title": "Launch Custom Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.launchAgentInWorktree",
        "title": "New Agent in Isolated Worktree…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lookout.splitCodex",
        "title": "Split with Codex",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.splitClaude",
        "title": "Split with Claude Code",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.splitSession",
        "title": "Split with Same Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "lookout.focusSession",
        "title": "Focus Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.renameSession",
        "title": "Rename Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.closeSession",
        "title": "Remove Agent",
        "category": "Lookout",
        "icon": "$(trash)"
      },
      {
        "command": "lookout.markNeedsAttention",
        "title": "Mark as Needs Attention",
        "category": "Lookout"
      },
      {
        "command": "lookout.restartSession",
        "title": "Restart Agent Command",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.copyNotifyCommand",
        "title": "Copy Attention Hook Command",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.focusNextAttention",
        "title": "Focus Next Agent Needing Attention",
        "category": "Lookout"
      },
      {
        "command": "lookout.pickSession",
        "title": "Focus Agent…",
        "category": "Lookout",
        "icon": "$(list-selection)"
      },
      {
        "command": "lookout.focusNextSession",
        "title": "Focus Next Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.focusPreviousSession",
        "title": "Focus Previous Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.refreshSessions",
        "title": "Refresh Agents",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.toggleAttentionSound",
        "title": "Mute or Unmute Attention Sound",
        "category": "Lookout",
        "icon": "$(unmute)"
      },
      {
        "command": "lookout.adoptTerminal",
        "title": "Adopt Existing Terminal as Agent…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(link)"
      },
      {
        "command": "lookout.muteAttentionSound",
        "title": "Mute Attention Sound",
        "category": "Lookout",
        "icon": "$(unmute)"
      },
      {
        "command": "lookout.unmuteAttentionSound",
        "title": "Unmute Attention Sound",
        "category": "Lookout",
        "icon": "$(mute)"
      },
      {
        "command": "lookout.configureAttentionSound",
        "title": "Configure Attention Sound",
        "category": "Lookout",
        "icon": "$(settings-gear)"
      },
      {
        "command": "lookout.testAttentionSound",
        "title": "Test Attention Sound",
        "category": "Lookout",
        "icon": "$(play)"
      },
      {
        "command": "lookout.refreshReview",
        "title": "Refresh Review Items",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.refreshUsage",
        "title": "Refresh Usage Limits",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.openBrowser",
        "title": "Open Browser",
        "category": "Lookout",
        "icon": "$(globe)"
      },
      {
        "command": "lookout.openSourceControl",
        "title": "Open Source Control",
        "category": "Lookout",
        "icon": "$(git-compare)"
      },
      {
        "command": "lookout.openTestExplorer",
        "title": "Open Test Explorer",
        "category": "Lookout",
        "icon": "$(beaker)"
      },
      {
        "command": "lookout.runTestTask",
        "title": "Run Test Task",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(run)"
      },
      {
        "command": "lookout.startDebug",
        "title": "Start Debugging…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(debug-alt)"
      },
      {
        "command": "lookout.openReviewLayout",
        "title": "Open Review Layout",
        "category": "Lookout",
        "icon": "$(layout-two-columns)"
      },
      {
        "command": "lookout.runTask",
        "title": "Run Workspace Task",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(play)"
      },
      {
        "command": "lookout.openReviewItem",
        "title": "Open Review Item",
        "category": "Lookout"
      }
    ],
    "keybindings": [
      {
        "command": "lookout.launchCodex",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "lookout.launchClaude",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "lookout.openBrowser",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b"
      },
      {
        "command": "lookout.focusNextAttention",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lookout",
          "title": "Lookout",
          "icon": "resources/lookout.svg"
        }
      ]
    },
    "views": {
      "lookout": [
        {
          "id": "lookout.sessions",
          "name": "Agents",
          "icon": "$(terminal)"
        },
        {
          "id": "lookout.review",
          "name": "Review",
          "icon": "$(preview)"
        },
        {
          "id": "lookout.usage",
          "name": "Usage Limits",
          "icon": "$(dashboard)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lookout.sessions",
        "contents": "No agents are running.\n[Launch Codex](command:lookout.launchCodex)\n[Launch Claude Code](command:lookout.launchClaude)\n[Adopt an existing terminal](command:lookout.adoptTerminal)",
        "when": "isWorkspaceTrusted"
      },
      {
        "view": "lookout.sessions",
        "contents": "Trust this workspace to launch or adopt terminal agents. Review and usage views remain available.\n[Manage Workspace Trust](command:workbench.trust.manage)",
        "when": "!isWorkspaceTrusted"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lookout.focusSession",
          "when": "false"
        },
        {
          "command": "lookout.renameSession",
          "when": "false"
        },
        {
          "command": "lookout.closeSession",
          "when": "false"
        },
        {
          "command": "lookout.restartSession",
          "when": "false"
        },
        {
          "command": "lookout.markNeedsAttention",
          "when": "false"
        },
        {
          "command": "lookout.copyNotifyCommand",
          "when": "false"
        },
        {
          "command": "lookout.splitSession",
          "when": "false"
        },
        {
          "command": "lookout.openReviewItem",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "lookout.launchAgent",
          "when": "view == lookout.sessions && isWorkspaceTrusted",
          "group": "navigation@1"
        },
        {
          "command": "lookout.launchAgentInWorktree",
          "when": "view == lookout.sessions && isWorkspaceTrusted",
          "group": "navigation@2"
        },
        {
          "command": "lookout.adoptTerminal",
          "when": "view == lookout.sessions && isWorkspaceTrusted",
          "group": "navigation@3"
        },
        {
          "command": "lookout.refreshSessions",
          "when": "view == lookout.sessions",
          "group": "navigation@4"
        },
        {
          "command": "lookout.muteAttentionSound",
          "when": "view == lookout.sessions && lookout.attentionSoundEnabled",
          "group": "navigation@5"
        },
        {
          "command": "lookout.unmuteAttentionSound",
          "when": "view == lookout.sessions && !lookout.attentionSoundEnabled",
          "group": "navigation@5"
        },
        {
          "command": "lookout.configureAttentionSound",
          "when": "view == lookout.sessions",
          "group": "navigation@6"
        },
        {
          "command": "lookout.openBrowser",
          "when": "view == lookout.review",
          "group": "navigation@1"
        },
        {
          "command": "lookout.openSourceControl",
          "when": "view == lookout.review",
          "group": "navigation@2"
        },
        {
          "command": "lookout.runTask",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "navigation@3"
        },
        {
          "command": "lookout.refreshReview",
          "when": "view == lookout.review",
          "group": "navigation@4"
        },
        {
          "command": "lookout.refreshUsage",
          "when": "view == lookout.usage",
          "group": "navigation@1"
        }
      ],
      "terminal/context": [
        {
          "command": "lookout.adoptTerminal",
          "when": "terminalIsOpen && isWorkspaceTrusted",
          "group": "navigation@10"
        }
      ],
      "view/item/context": [
        {
          "command": "lookout.splitSession",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "inline@1"
        },
        {
          "command": "lookout.openTestExplorer",
          "when": "view == lookout.review",
          "group": "lookout@1"
        },
        {
          "command": "lookout.runTestTask",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "lookout@2"
        },
        {
          "command": "lookout.startDebug",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "lookout@3"
        },
        {
          "command": "lookout.openReviewLayout",
          "when": "view == lookout.review",
          "group": "navigation@5"
        },
        {
          "command": "lookout.closeSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "inline@2"
        },
        {
          "command": "lookout.markNeedsAttention",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@1"
        },
        {
          "command": "lookout.restartSession",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "lookout@2"
        },
        {
          "command": "lookout.copyNotifyCommand",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "lookout@3"
        },
        {
          "command": "lookout.renameSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@4"
        },
        {
          "command": "lookout.closeSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@5"
        }
      ]
    },
    "configuration": {
      "title": "Lookout",
      "properties": {
        "lookout.codex.command": {
          "type": "string",
          "default": "codex",
          "description": "Command used to launch a Codex CLI session."
        },
        "lookout.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Codex in the new-agent picker."
        },
        "lookout.codex.lifecycleIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add session-only Codex lifecycle hooks and a turn-complete fallback so Lookout can distinguish working, delegated agents, authorization checks, and a finished turn. Codex requires one-time review through /hooks."
        },
        "lookout.claude.command": {
          "type": "string",
          "default": "claude",
          "description": "Command used to launch a Claude Code session."
        },
        "lookout.claude.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Claude Code in the new-agent picker."
        },
        "lookout.claude.lifecycleIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add session-only Claude hooks so Lookout can distinguish working, delegated agents, permissions, waiting for input, and turn completion."
        },
        "lookout.terminals.location": {
          "type": "string",
          "enum": [
            "editor",
            "panel"
          ],
          "enumDescriptions": [
            "Use the main editor area for terminal agents.",
            "Use VS Code's terminal panel."
          ],
          "default": "editor",
          "description": "Where new agent terminals open."
        },
        "lookout.notifyOnAgentExit": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when an agent command exits."
        },
        "lookout.notifyOnAttention": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a background agent hook requests attention."
        },
        "lookout.notifyOnTurnComplete": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a background agent hook reports a finished turn — the agent going idle at its prompt, or a completed or failed run."
        },
        "lookout.attentionSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Play Lookout's bell when an unattended agent starts waiting for input, finishes a turn, or exits."
        },
        "lookout.attentionSound.volume": {
          "type": "number",
          "default": 35,
          "minimum": 0,
          "maximum": 100,
          "description": "Volume of Lookout's attention bell. Set to 0 to mute it."
        },
        "lookout.usage.codex.executable": {
          "type": "string",
          "default": "codex",
          "description": "Codex executable used for structured rate-limit queries. Reload the window after changing this setting."
        },
        "lookout.usage.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Codex usage and start its structured rate-limit provider. Reload the window after changing this setting."
        },
        "lookout.usage.codex.showSparkLimits": {
          "type": "boolean",
          "default": false,
          "description": "Show separate GPT Codex Spark rate-limit buckets in the Usage Limits view."
        },
        "lookout.usage.claude.statusLineIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add a Lookout status-line bridge to extension-launched Claude sessions so subscription limits can be tracked."
        },
        "lookout.usage.claude.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Claude usage limits."
        },
        "lookout.usage.warningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "Usage percentage at which limit indicators turn to warning state."
        },
        "lookout.usage.criticalThreshold": {
          "type": "number",
          "default": 95,
          "minimum": 1,
          "maximum": 100,
          "description": "Usage percentage at which limit indicators turn to critical state."
        },
        "lookout.review.showRecentImages": {
          "type": "boolean",
          "default": false,
          "description": "Show and scan the Recent Images group in the Review view."
        },
        "lookout.review.imageGlob": {
          "type": "string",
          "default": "**/*.{png,jpg,jpeg,gif,webp}",
          "description": "Glob used to find reviewable image artifacts."
        },
        "lookout.review.artifactGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/{plans,docs}/**/*.{md,mdx,txt}",
            "**/todos/**/*.{md,mdx,txt}",
            "**/{TODOS,DESIGN,TESTPLAN}.{md,mdx,txt}"
          ],
          "description": "Globs used to find plans, documentation, and Compound Engineering artifacts for review."
        },
        "lookout.review.maxItemsPerGroup": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum recent review items shown in each group."
        },
        "lookout.browser.defaultUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL prefilled by the Open Browser command."
        }
      }
    }
  }
}
