      },
      {
        "command": "lookout.focusPreviousUnread",
        "title": "Focus Previous Unread Agent Event",
        "category": "Lookout",
        "icon": "$(arrow-up)"
      },
      {
        "command": "lookout.resumeSession",
        "title": "Resume Provider Session",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(debug-restart)"
      },
      {
        "command": "lookout.forkSession",
        "title": "Fork Provider Session",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lookout.archiveSession",
        "title": "Archive Lookout History",
        "category": "Lookout",
        "icon": "$(archive)"
      },
      {
        "command": "lookout.unarchiveSession",
        "title": "Unarchive Lookout History",
        "category": "Lookout",
        "icon": "$(history)"
      },
      {
        "command": "lookout.configureCrossWindowCoordination",
        "title": "Configure Cross-Window Coordination",
        "category": "Lookout",
        "icon": "$(broadcast)"
      },
      {
        "command": "lookout.openGlobalHistory",
        "title": "Open Historical Project",
        "category": "Lookout",
        "icon": "$(folder-opened)"
      },
      {
        "command": "lookout.resumeGlobalSession",
        "title": "Open Project and Resume Provider Session",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(debug-restart)"
      },
      {
        "command": "lookout.forkGlobalSession",
        "title": "Open Project and Fork Provider Session",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lookout.deleteGlobalHistory",
        "title": "Delete Cross-Project History",
        "category": "Lookout",
        "icon": "$(trash)"
      },
      {
        "command": "lookout.focusRemoteSession",
        "title": "Focus Agent in Owning Window",
        "category": "Lookout",
        "icon": "$(broadcast)"
      },
      {
        "command": "lookout.deleteHistory",
        "title": "Delete Closed Lookout History",
        "category": "Lookout",
        "icon": "$(trash)"
      },
      {
        "command": "lookout.pickSession",
        "title": "Focus Agent…",
        "category": "Lookout",
        "icon": "$(list-selection)"
      },
      {
        "command": "lookout.focusNextSession",
        "title": "Focus Next Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.focusPreviousSession",
        "title": "Focus Previous Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.refreshSessions",
        "title": "Refresh Agents",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.toggleAttentionSound",
        "title": "Mute or Unmute Attention Sound",
        "category": "Lookout",
        "icon": "$(unmute)"
      },
      {
        "command": "lookout.adoptTerminal",
        "title": "Adopt Existing Terminal as Agent…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(link)"
      },
      {
        "command": "lookout.muteAttentionSound",
        "title": "Mute Attention Sound",
        "category": "Lookout",
        "icon": "$(unmute)"
      },
      {
        "command": "lookout.unmuteAttentionSound",
        "title": "Unmute Attention Sound",
        "category": "Lookout",
        "icon": "$(mute)"
      },
      {
        "command": "lookout.configureAttentionSound",
        "title": "Configure Attention Sound",
        "category": "Lookout",
        "icon": "$(settings-gear)"
      },
      {
        "command": "lookout.testAttentionSound",
        "title": "Test Attention Sound",
        "category": "Lookout",
        "icon": "$(play)"
      },
      {
        "command": "lookout.refreshReview",
        "title": "Refresh Review Items",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.refreshUsage",
        "title": "Refresh Usage Limits",
        "category": "Lookout",
        "icon": "$(refresh)"
      },
      {
        "command": "lookout.openBrowser",
        "title": "Open Browser",
        "category": "Lookout",
        "icon": "$(globe)"
      },
      {
        "command": "lookout.openSourceControl",
        "title": "Open Source Control",
        "category": "Lookout",
        "icon": "$(git-compare)"
      },
      {
        "command": "lookout.openTestExplorer",
        "title": "Open Test Explorer",
        "category": "Lookout",
        "icon": "$(beaker)"
      },
      {
        "command": "lookout.runTestTask",
        "title": "Run Test Task",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(run)"
      },
      {
        "command": "lookout.runVerification",
        "title": "Run Verification Task…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(verified)"
      },
      {
        "command": "lookout.startDebug",
        "title": "Start Debugging…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(debug-alt)"
      },
      {
        "command": "lookout.openReviewLayout",
        "title": "Open Review Layout",
        "category": "Lookout",
        "icon": "$(layout-two-columns)"
      },
      {
        "command": "lookout.runTask",
        "title": "Run Workspace Task",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(play)"
      },
      {
        "command": "lookout.openReviewItem",
        "title": "Open Review Item",
        "category": "Lookout"
      }
    ],
    "keybindings": [
      {
        "command": "lookout.launchCodex",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "lookout.launchClaude",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "lookout.openBrowser",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b"
      },
      {
        "command": "lookout.focusNextAttention",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lookout",
          "title": "Lookout",
          "icon": "resources/lookout.svg"
        }
      ]
    },
    "views": {
      "lookout": [
        {
          "id": "lookout.sessions",
          "name": "Agents",
          "icon": "$(terminal)"
        },
        {
          "id": "lookout.review",
          "name": "Review",
          "icon": "$(preview)"
        },
        {
          "id": "lookout.usage",
          "name": "Usage Limits",
          "icon": "$(dashboard)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "lookout.sessions",
        "contents": "No agents are running.\n[Launch an agent](command:lookout.launchAgent)\n[Check agent profiles](command:lookout.configureProfiles)\n[Adopt an existing terminal](command:lookout.adoptTerminal)",
        "when": "isWorkspaceTrusted"
      },
      {
        "view": "lookout.sessions",
        "contents": "Trust this workspace to launch or adopt terminal agents. Review and usage views remain available.\n[Manage Workspace Trust](command:workbench.trust.manage)",
        "when": "!isWorkspaceTrusted"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lookout.focusSession",
          "when": "false"
        },
        {
          "command": "lookout.renameSession",
          "when": "false"
        },
        {
          "command": "lookout.closeSession",
          "when": "false"
        },
        {
          "command": "lookout.restartSession",
          "when": "false"
        },
        {
          "command": "lookout.markNeedsAttention",
          "when": "false"
        },
        {
          "command": "lookout.copyNotifyCommand",
          "when": "false"
        },
        {
          "command": "lookout.splitSession",
          "when": "false"
        },
        {
          "command": "lookout.openReviewItem",
          "when": "false"
        },
        {
          "command": "lookout.resumeSession",
          "when": "false"
        },
        {
          "command": "lookout.forkSession",
          "when": "false"
        },
        {
          "command": "lookout.archiveSession",
          "when": "false"
        },
        {
          "command": "lookout.unarchiveSession",
          "when": "false"
        },
        {
          "command": "lookout.openGlobalHistory",
          "when": "false"
        },
        {
          "command": "lookout.resumeGlobalSession",
          "when": "false"
        },
        {
          "command": "lookout.forkGlobalSession",
          "when": "false"
        },
        {
          "command": "lookout.deleteGlobalHistory",
          "when": "false"
        },
        {
          "command": "lookout.focusRemoteSession",
          "when": "false"
        },
        {
          "command": "lookout.splitCodex",
          "when": "false"
        },
        {
          "command": "lookout.splitClaude",
          "when": "false"
        },
        {
          "command": "lookout.refreshSessions",
          "when": "false"
        },
        {
          "command": "lookout.refreshReview",
          "when": "false"
        },
        {
          "command": "lookout.refreshUsage",
          "when": "false"
        },
        {
          "command": "lookout.muteAttentionSound",
          "when": "false"
        },
        {
          "command": "lookout.unmuteAttentionSound",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "lookout.launchAgent",
          "when": "view == lookout.sessions && isWorkspaceTrusted",
          "group": "navigation@1"
        },
        {
          "command": "lookout.adoptTerminal",
          "when": "view == lookout.sessions && isWorkspaceTrusted",
          "group": "navigation@3"
        },
        {
          "command": "lookout.refreshSessions",
          "when": "view == lookout.sessions",
          "group": "navigation@4"
        },
        {
          "command": "lookout.muteAttentionSound",
          "when": "view == lookout.sessions && lookout.attentionSoundEnabled",
          "group": "navigation@5"
        },
        {
          "command": "lookout.unmuteAttentionSound",
          "when": "view == lookout.sessions && !lookout.attentionSoundEnabled",
          "group": "navigation@5"
        },
        {
          "command": "lookout.openSettings",
          "when": "view == lookout.sessions",
          "group": "navigation@6"
        },
        {
          "command": "lookout.launchTemplate",
          "when": "view == lookout.sessions && isWorkspaceTrusted && lookout.hasTemplates",
          "group": "navigation@2.5"
        },
        {
          "command": "lookout.openBrowser",
          "when": "view == lookout.review",
          "group": "navigation@1"
        },
        {
          "command": "lookout.openSourceControl",
          "when": "view == lookout.review",
          "group": "navigation@2"
        },
        {
          "command": "lookout.runVerification",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "navigation@3"
        },
        {
          "command": "lookout.runTask",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "navigation@3.5"
        },
        {
          "command": "lookout.refreshReview",
          "when": "view == lookout.review",
          "group": "navigation@4"
        },
        {
          "command": "lookout.refreshUsage",
          "when": "view == lookout.usage",
          "group": "navigation@1"
        }
      ],
      "terminal/context": [
        {
          "command": "lookout.adoptTerminal",
          "when": "terminalIsOpen && isWorkspaceTrusted",
          "group": "navigation@10"
        }
      ],
      "view/item/context": [
        {
          "command": "lookout.splitSession",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "inline@1"
        },
        {
          "command": "lookout.openTestExplorer",
          "when": "view == lookout.review",
          "group": "lookout@1"
        },
        {
          "command": "lookout.runTestTask",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "lookout@2"
        },
        {
          "command": "lookout.runVerification",
          "when": "view == lookout.review && viewItem == lookout.reviewWorktree && isWorkspaceTrusted",
          "group": "lookout@2.5"
        },
        {
          "command": "lookout.startDebug",
          "when": "view == lookout.review && isWorkspaceTrusted",
          "group": "lookout@3"
        },
        {
          "command": "lookout.openReviewLayout",
          "when": "view == lookout.review",
          "group": "navigation@5"
        },
        {
          "command": "lookout.closeSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "inline@2"
        },
        {
          "command": "lookout.markNeedsAttention",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@1"
        },
        {
          "command": "lookout.restartSession",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "lookout@2"
        },
        {
          "command": "lookout.copyNotifyCommand",
          "when": "view == lookout.sessions && viewItem == lookout.session && isWorkspaceTrusted",
          "group": "lookout@3"
        },
        {
          "command": "lookout.renameSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@4"
        },
        {
          "command": "lookout.closeSession",
          "when": "view == lookout.sessions && viewItem == lookout.session",
          "group": "lookout@5"
        },
        {
          "command": "lookout.focusRemoteSession",
          "when": "view == lookout.sessions && viewItem == lookout.liveSession",
          "group": "inline@1"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "lookout.gettingStarted",
        "title": "Coordinate terminal agents with Lookout",
        "description": "Detect a provider, launch or resume a real terminal session, route attention, and review work with explicit evidence.",
        "steps": [
          {
            "id": "lookout.walkthrough.profiles",
            "title": "Check your agent profiles",
            "description": "[Inspect detected Codex, Claude Code, and generic terminal profiles](command:lookout.configureProfiles). Lookout never installs or authenticates a provider for you.",
            "completionEvents": [
              "onCommand:lookout.configureProfiles"
            ],
            "media": {
              "image": "assets/screenshots/lookout-overview.png",
              "altText": "Lookout Agents, Review, and Usage views"
            }
          },
          {
            "id": "lookout.walkthrough.launch",
            "title": "Launch a native agent terminal",
            "description": "[Launch an agent](command:lookout.launchAgent) or [create a reusable session template](command:lookout.createTemplate). Provider UX stays in its real terminal.",
            "completionEvents": [
              "onCommand:lookout.launchAgent"
            ],
            "media": {
              "image": "assets/screenshots/lookout-overview.png",
              "altText": "Lookout sidebar with native terminal agents"
            }
          },
          {
            "id": "lookout.walkthrough.attention",
            "title": "Triage explicit agent events",
            "description": "Watch the **Agents** view badges and status bar, and [focus the next unread agent](command:lookout.focusNextUnread). Lookout uses provider hooks and never scrapes terminal output.",
            "completionEvents": [
              "onCommand:lookout.focusNextUnread"
            ],
            "media": {
              "image": "assets/screenshots/usage-status.png",
              "altText": "Lookout finished-turn notification and status bar"
            }
          },
          {
            "id": "lookout.walkthrough.review",
            "title": "Review and verify in VS Code",
            "description": "[Open the review layout](command:lookout.openReviewLayout) for native diffs, Problems, Tasks, tests, debugging, and browser tools.",
            "completionEvents": [
              "onCommand:lookout.openReviewLayout"
            ],
            "media": {
              "image": "assets/screenshots/lookout-overview.png",
              "altText": "Lookout Review view with workspace evidence"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Lookout",
      "properties": {
        "lookout.codex.command": {
          "type": "string",
          "default": "codex",
          "description": "Command used to launch a Codex CLI session."
        },
        "lookout.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Codex in the new-agent picker."
        },
        "lookout.codex.lifecycleIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add session-only Codex lifecycle hooks and a turn-complete fallback so Lookout can distinguish working, delegated agents, authorization checks, and a finished turn. Codex requires one-time review through /hooks."
        },
        "lookout.claude.command": {
          "type": "string",
          "default": "claude",
          "description": "Command used to launch a Claude Code session."
        },
        "lookout.claude.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Claude Code in the new-agent picker."
        },
        "lookout.claude.lifecycleIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add session-only Claude hooks so Lookout can distinguish working, delegated agents, permissions, waiting for input, and turn completion."
        },
        "lookout.terminals.location": {
          "type": "string",
          "enum": [
            "editor",
            "panel"
          ],
          "enumDescriptions": [
            "Use the main editor area for terminal agents.",
            "Use VS Code's terminal panel."
          ],
          "default": "panel",
          "description": "Where new agent terminals open."
        },
        "lookout.notifyOnAgentExit": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when an agent command exits."
        },
        "lookout.notifyOnAttention": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a background agent hook requests attention."
        },
        "lookout.notifyOnTurnComplete": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a background agent hook reports a finished turn — the agent going idle at its prompt, or a completed or failed run."
        },
        "lookout.attentionSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Play Lookout's bell when an unattended agent starts waiting for input, finishes a turn, or exits."
        },
        "lookout.attentionSound.volume": {
          "type": "number",
          "default": 35,
          "minimum": 0,
          "maximum": 100,
          "description": "Volume of Lookout's attention bell. Set to 0 to mute it."
        },
        "lookout.usage.codex.executable": {
          "type": "string",
          "default": "codex",
          "description": "Codex executable used for structured rate-limit queries. Reload the window after changing this setting."
        },
        "lookout.usage.codex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Codex usage and start its structured rate-limit provider. Reload the window after changing this setting."
        },
        "lookout.usage.codex.showSparkLimits": {
          "type": "boolean",
          "default": false,
          "description": "Show separate GPT Codex Spark rate-limit buckets in the Usage Limits view."
        },
        "lookout.usage.codex.tokenBudget": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Provider-managed rollout token budget applied to newly launched direct Codex sessions. Set to 0 to disable. Requires a Codex CLI version that supports rollout budgets."
        },
        "lookout.usage.claude.statusLineIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Add Lookout status-line bridges to extension-launched Claude sessions so subscription limits, live context tokens, estimated session cost, and delegated-agent token counts can be tracked."
        },
        "lookout.usage.claude.contextWarningTokens": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Highlight newly launched Claude sessions when their current context reaches this many tokens. This is a warning, not a cumulative token cap, and does not stop Claude. Set to 0 to disable."
        },
        "lookout.usage.claude.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Claude usage limits."
        },
        "lookout.usage.warningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "description": "Usage percentage at which limit indicators turn to warning state."
        },
        "lookout.usage.criticalThreshold": {
          "type": "number",
          "default": 95,
          "minimum": 1,
          "maximum": 100,
          "description": "Usage percentage at which limit indicators turn to critical state."
        },
        "lookout.review.showRecentImages": {
          "type": "boolean",
          "default": false,
          "description": "Show and scan the Recent Images group in the Review view."
        },
        "lookout.review.captureCommandOutput": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Capture up to 8 KiB of explicit Codex and Claude command results for newly launched sessions. Results are kept only in memory until the window reloads or session closes and may contain sensitive data."
        },
        "lookout.review.imageGlob": {
          "type": "string",
          "default": "**/*.{png,jpg,jpeg,gif,webp}",
          "description": "Glob used to find reviewable image artifacts."
        },
        "lookout.review.artifactGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/{plans,docs}/**/*.{md,mdx,txt}",
            "**/todos/**/*.{md,mdx,txt}",
            "**/{TODOS,DESIGN,TESTPLAN}.{md,mdx,txt}"
          ],
          "description": "Globs used to find plans, documentation, and Compound Engineering artifacts for review."
        },
        "lookout.review.maxItemsPerGroup": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum recent review items shown in each group."
        },
        "lookout.history.globalEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Keep bounded cross-project Lookout history in extension-global storage on this execution host. Reload the window after changing this setting. History is not Settings Sync data."
        },
        "lookout.experimental.crossWindowCoordination": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Share live, metadata-only agent state between Lookout windows on the same VS Code profile and execution host through an authenticated loopback coordinator. Local, WSL, SSH, and container hosts are never federated."
        },
        "lookout.browser.defaultUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL prefilled by the Open Browser command."
        }
      }
    }
  }
}
