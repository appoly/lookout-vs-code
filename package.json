{
  "name": "lookout",
  "displayName": "Lookout",
  "description": "Run, monitor, and review Codex, Claude Code, and custom terminal agents in parallel without leaving VS Code.",
  "version": "1.0.0",
  "publisher": "appoly",
  "license": "MIT",
  "preview": true,
  "pricing": "Free",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#101827",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/appoly/lookout-vs-code.git"
  },
  "homepage": "https://github.com/appoly/lookout-vs-code#readme",
  "bugs": {
    "url": "https://github.com/appoly/lookout-vs-code/issues"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "multi-agent",
    "terminal",
    "agents",
    "codex",
    "codex cli",
    "claude",
    "claude code",
    "worktree",
    "code review",
    "usage limits",
    "orchestration",
    "multiplexer"
  ],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Review and usage views remain available; launching configured terminal commands requires a trusted workspace.",
      "restrictedConfigurations": [
        "lookout.codex.command",
        "lookout.claude.command",
        "lookout.usage.codex.executable",
        "lookout.review.showRecentImages",
        "lookout.review.imageGlob",
        "lookout.review.artifactGlobs"
      ]
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Lookout requires native terminals, local or remote filesystem paths, and Git processes."
    }
  },
  "files": [
    "assets/screenshots/**",
    "out/src/**",
    "resources/**",
    "README.md",
    "CHANGELOG.md",
    "PRIVACY.md",
    "SECURITY.md",
    "SUPPORT.md",
    "LICENSE"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run clean && tsc -p ./ --sourceMap false",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "lint": "eslint src test",
    "test": "npm run clean && npm run compile && node --test out/test/**/*.test.js",
    "test:provider-compat": "npm run clean && npm run compile && node --test out/test/providerCompatibility.test.js",
    "compat:providers": "node scripts/provider-compat.mjs",
    "test:integration": "npm run compile && vscode-test --label integration --fail-zero --forbid-only",
    "verify:vsix": "npm run vsix && npm run verify:installed-vsix",
    "verify:installed-vsix": "node scripts/verify-vsix.mjs",
    "verify:vsix-contents": "node scripts/verify-vsix-contents.mjs",
    "check": "npm run check:repository && npm run lint && npm test",
    "check:all": "npm run check && npm run test:integration",
    "audit:runtime": "npm audit --omit=dev",
    "check:repository": "node scripts/check-repository.mjs",
    "check:release": "npm run check:all && npm run audit:runtime && npm run verify:vsix",
    "vsix": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.17.0",
    "@types/vscode": "1.96.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.31.0",
    "ovsx": "1.0.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "yauzl": "3.4.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "lookout.launchAgent",
        "title": "New Agent…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.configureProfiles",
        "title": "Configure Agent Profiles",
        "category": "Lookout",
        "icon": "$(settings-gear)"
      },
      {
        "command": "lookout.openSettings",
        "title": "Open Lookout Settings",
        "category": "Lookout",
        "icon": "$(settings-gear)"
      },
      {
        "command": "lookout.runDoctor",
        "title": "Run Doctor",
        "category": "Lookout",
        "icon": "$(pulse)"
      },
      {
        "command": "lookout.exportSupportBundle",
        "title": "Export Sanitized Support Bundle…",
        "category": "Lookout",
        "icon": "$(export)"
      },
      {
        "command": "lookout.createTemplate",
        "title": "Create Session Template…",
        "category": "Lookout",
        "icon": "$(new-file)"
      },
      {
        "command": "lookout.launchTemplate",
        "title": "Launch Agent from Template…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(rocket)"
      },
      {
        "command": "lookout.deleteTemplate",
        "title": "Delete Session Template…",
        "category": "Lookout"
      },
      {
        "command": "lookout.launchCodex",
        "title": "Launch Codex Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.launchClaude",
        "title": "Launch Claude Code Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(add)"
      },
      {
        "command": "lookout.launchCustom",
        "title": "Launch Custom Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.launchAgentInWorktree",
        "title": "New Agent in Isolated Worktree…",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lookout.splitCodex",
        "title": "Split with Codex",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.splitClaude",
        "title": "Split with Claude Code",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.splitSession",
        "title": "Split with Same Agent",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "lookout.focusSession",
        "title": "Focus Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.renameSession",
        "title": "Rename Agent",
        "category": "Lookout"
      },
      {
        "command": "lookout.closeSession",
        "title": "Remove Agent",
        "category": "Lookout",
        "icon": "$(trash)"
      },
      {
        "command": "lookout.markNeedsAttention",
        "title": "Mark as Needs Attention",
        "category": "Lookout"
      },
      {
        "command": "lookout.restartSession",
        "title": "Restart Agent Command",
        "category": "Lookout",
        "enablement": "isWorkspaceTrusted"
      },
      {
        "command": "lookout.copyNotifyCommand",
        "title": "Copy Attention Hook Command",
